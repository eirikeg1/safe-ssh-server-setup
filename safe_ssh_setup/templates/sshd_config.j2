# SSH Server Configuration
# Generated by safe-ssh-setup on {{ timestamp }}
# Do not edit manually — re-run safe-ssh-setup to modify.

Port {{ ssh.port }}
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

# ---- Authentication ----
PermitRootLogin {{ ssh.permit_root_login }}
PubkeyAuthentication {{ "yes" if ssh.pubkey_authentication else "no" }}
PasswordAuthentication {{ "yes" if ssh.password_authentication else "no" }}
PermitEmptyPasswords {{ "yes" if ssh.permit_empty_passwords else "no" }}
KbdInteractiveAuthentication {{ "yes" if ssh.kbd_interactive_auth else "no" }}
ChallengeResponseAuthentication no
UsePAM yes
MaxAuthTries {{ ssh.max_auth_tries }}
LoginGraceTime {{ ssh.login_grace_time }}

# ---- Session ----
ClientAliveInterval {{ ssh.client_alive_interval }}
ClientAliveCountMax {{ ssh.client_alive_count_max }}
MaxSessions 3

# ---- Forwarding ----
X11Forwarding {{ "yes" if ssh.x11_forwarding else "no" }}
AllowAgentForwarding {{ "yes" if ssh.allow_agent_forwarding else "no" }}
AllowTcpForwarding {{ "yes" if ssh.allow_tcp_forwarding else "no" }}

# ---- Cryptography ----
Ciphers {{ ssh.ciphers | join(",") }}
MACs {{ ssh.macs | join(",") }}
KexAlgorithms {{ ssh.kex_algorithms | join(",") }}

# ---- Logging ----
LogLevel VERBOSE
SyslogFacility AUTH

# ---- Misc ----
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
