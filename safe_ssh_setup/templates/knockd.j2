# Port Knocking Configuration
# Generated by safe-ssh-setup on {{ timestamp }}
#
# To connect: knock -v server_ip {{ knock.sequence | join(" ") }}
# Then:       ssh -p {{ ssh_port }} user@server_ip

[options]
    UseSyslog

[openSSH]
    sequence    = {{ knock.sequence | join(",") }}
    seq_timeout = {{ knock.seq_timeout }}
    command     = /sbin/iptables -A INPUT -s %IP% -p tcp --dport {{ ssh_port }} -j ACCEPT
    tcpflags    = syn

[closeSSH]
    sequence    = {{ knock.sequence | reverse | join(",") }}
    seq_timeout = {{ knock.seq_timeout }}
    command     = /sbin/iptables -D INPUT -s %IP% -p tcp --dport {{ ssh_port }} -j ACCEPT
    tcpflags    = syn
