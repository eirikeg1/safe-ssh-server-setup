# Fail2Ban SSH Jail Configuration
# Generated by safe-ssh-setup on {{ timestamp }}

[DEFAULT]
banaction = iptables-multiport
banaction_allports = iptables-allports

[{{ ssh_service }}]
enabled = true
port = {{ ssh_port }}
filter = {{ ssh_service }}
maxretry = {{ f2b.max_retry }}
findtime = {{ f2b.find_time }}
bantime = {{ f2b.ban_time }}
logpath = %(sshd_log)s
backend = %(sshd_backend)s
